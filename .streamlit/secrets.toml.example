# 複製此檔案為 secrets.toml，填入實際值（本機測試用）
# Streamlit Cloud 部署時直接在網頁介面的 Secrets 貼入相同內容

# ── 登入帳號設定 ─────────────────────────────────────────────────────────────
[credentials.usernames.admin]
name = "管理員"
password = "$2b$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"  # bcrypt hash

[credentials.usernames.user1]
name = "使用者一"
password = "$2b$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── Cookie 設定 ──────────────────────────────────────────────────────────────
[cookie]
name     = "power_monitor_auth"
key      = "請填入一段隨機字串，例如 openssl rand -hex 32 的輸出"
expiry_days = 7

# ── Google Sheet ─────────────────────────────────────────────────────────────
[google_sheet]
sheet_id   = "你的 Google Sheet ID"
sheet_name = "監控紀錄Log"

# ── Google Service Account（把 service_account.json 整個內容貼在這） ──────────
gcp_service_account = '''
{
  "type": "service_account",
  "project_id": "...",
  "private_key_id": "...",
  "private_key": "-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n",
  "client_email": "...",
  "client_id": "...",
  "auth_uri": "https://accounts.google.com/o/oauth2/auth",
  "token_uri": "https://oauth2.googleapis.com/token"
}
'''
